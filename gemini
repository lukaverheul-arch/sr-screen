<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>SR Screening — Antimalarial Resistance West Africa (v33)</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f1117; --surface: #181c27; --surface2: #1e2333; --border: #2a2f42; --border2: #353c55;
    --text: #e2e6f0; --text2: #8b92a8; --text3: #555e78; --inc: #2dd4a0; --inc-bg: #0d2e24;
    --exc: #f0645a; --exc-bg: #2e100d; --maybe: #f5a623; --maybe-bg: #2e1e04; --dup: #a78bfa;
    --dup-bg: #1a1030; --accent: #4f8ef7; --accent-bg: #0d1e3a; --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 14px; min-height: 100vh; }
  .app-header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 14px 24px; display: flex; align-items: center; gap: 16px; position: sticky; top: 0; z-index: 100; }
  .app-title { font-family: var(--mono); font-size: 13px; color: var(--text2); letter-spacing: 0.04em; }
  .app-title span { color: var(--accent); }
  .header-sep { flex: 1; }
  .phase-badge { font-family: var(--mono); font-size: 11px; padding: 4px 10px; border-radius: 3px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; }
  .phase-import { background: var(--surface2); color: var(--text2); border: 1px solid var(--border2); }
  .tabs { display: flex; background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 24px; }
  .tab { font-family: var(--mono); font-size: 12px; padding: 12px 18px; cursor: pointer; color: var(--text3); border-bottom: 2px solid transparent; transition: all 0.15s; letter-spacing: 0.03em; display: flex; align-items: center; gap: 8px; user-select: none; }
  .tab.active { color: var(--text); border-bottom-color: var(--accent); }
  .tab-count { background: var(--surface2); border: 1px solid var(--border2); border-radius: 10px; padding: 1px 7px; font-size: 10px; color: var(--text2); }
  .stats-bar { display: flex; gap: 1px; background: var(--border); border-bottom: 1px solid var(--border); }
  .stat-cell { flex: 1; background: var(--surface); padding: 12px 20px; display: flex; flex-direction: column; gap: 2px; }
  .stat-label { font-family: var(--mono); font-size: 10px; color: var(--text3); letter-spacing: 0.08em; text-transform: uppercase; }
  .stat-value { font-family: var(--mono); font-size: 22px; font-weight: 500; }
  .main { padding: 20px 24px; max-width: 1400px; }
  .panel { display: none; }
  .panel.active { display: block; }
  .btn { font-family: var(--mono); font-size: 12px; padding: 9px 18px; border-radius: 4px; cursor: pointer; border: none; transition: all 0.15s; letter-spacing: 0.04em; font-weight: 500; text-decoration: none; display: inline-block; }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-ghost { background: transparent; color: var(--text2); border: 1px solid var(--border2); }
  .upload-row { display: flex; align-items: center; gap: 16px; padding: 16px 20px; background: var(--surface); border: 1px solid var(--border); border-radius: 6px; margin-bottom: 12px; }
  .upload-label { flex: 1; }
  .toast { position: fixed; bottom: 24px; right: 24px; background: var(--surface2); border: 1px solid var(--border2); border-radius: 4px; padding: 10px 16px; font-family: var(--mono); font-size: 12px; color: var(--text); z-index: 9999; opacity: 0; transform: translateY(8px); transition: all 0.2s; pointer-events: none; }
  .toast.show { opacity: 1; transform: translateY(0); }
</style>
</head>
<body>

<div class="app-header">
  <div class="app-title">SR·SCREEN / <span>Antimalarial Resistance — West Africa</span> <span style="color:var(--accent);font-size:11px;margin-left:8px">v33 (Gemini)</span></div>
  <div class="header-sep"></div>
  <div id="save-status" style="font-family:var(--mono);font-size:11px;color:var(--text3);margin-right:12px;display:flex;align-items:center;gap:6px">
    <span id="save-dot" style="width:6px;height:6px;border-radius:50%;background:var(--text3);display:inline-block"></span>
    <span id="save-label">No data</span>
  </div>
  <button class="btn btn-ghost" onclick="saveSession()" style="font-size:11px;padding:6px 12px;margin-right:8px">💾 Save Session</button>
  <label for="file-restore" class="btn btn-ghost" style="font-size:11px;padding:6px 12px;cursor:pointer;margin-right:12px">📂 Restore Session</label>
  <input type="file" id="file-restore" accept=".json" onchange="restoreSession(event)" style="display:none">
  <div id="phase-badge" class="phase-badge phase-import">v33 Ready</div>
</div>

<div class="tabs">
  <div class="tab active" onclick="switchTab('import')"><span>01 · Import</span></div>
  <div class="tab" onclick="switchTab('title')"><span>02 · Screening</span></div>
</div>

<div class="main">
  <div class="panel active" id="panel-import">
    <div class="upload-row">
      <div class="upload-label">
        <div style="font-weight:600">Load Session JSON</div>
        <div style="font-size:12px;color:var(--text3)">Upload your existing project file to apply v33 pre-screening.</div>
      </div>
      <input type="file" id="main-upload" accept=".json" onchange="restoreSession(event)" class="file-input" style="display:none">
      <label for="main-upload" class="btn btn-primary">Choose Session File</label>
    </div>
    <div style="margin-top:20px; display:flex; gap:10px;">
       <button class="btn btn-primary" onclick="applyEnhancedPrescreen()">🚀 Run Enhanced Pre-Screen (v33)</button>
    </div>
  </div>
</div>

<div id="toast" class="toast"></div>

<script>
let records = [];

const WEST_AFRICA = [
    'nigeria', 'ghana', 'senegal', 'mali', 'burkina faso', 'benin', 'togo', 'niger',
    'cameroon', 'guinea', 'liberia', 'sierra leone', 'gambia', 'mauritania', 'guinea-bissau', 'cabo verde', 'ivory coast', 'cote d\'ivoire'
];

const HARD_EXCLUDES = [
    ['in vitro', 'E1: In vitro study'],
    ['mouse', 'E1: Animal model'],
    ['mice', 'E1: Animal model'],
    ['monkey', 'E1: Animal model'],
    ['murine', 'E1: Animal model'],
    ['rat ', 'E1: Animal model'],
    ['mosquito', 'E3: Entomology (no parasite data)'],
    ['anopheles', 'E3: Entomology (no parasite data)'],
    ['entomology', 'E3: Entomology'],
    ['insecticide', 'E3: Vector control'],
    ['bed net', 'E3: Bed net study (entomology)'],
    ['salmonella', 'E2: Wrong pathogen'],
    ['staphylococcus', 'E2: Wrong pathogen'],
    ['hepatitis', 'E2: Wrong pathogen'],
    ['cost-effectiveness', 'E4: Economic analysis'],
    ['willingness to pay', 'E4: Economic analysis'],
    ['knowledge, attitude', 'E4: KAP study']
];

const AUTO_INCLUDES = [
    'pfcrt', 'pfmdr1', 'pfmdr2', 'pfdhfr', 'pfdhps', 'k13', 'kelch13',
    'artemisinin resistance', 'molecular marker', 'mutation frequency',
    'snp', 'single nucleotide polymorphism', 'haplotype', 'allele frequency'
];

function preScreen(title) {
    const t = title.toLowerCase();
    
    // 1. Check Hard Excludes
    for (const [term, reason] of HARD_EXCLUDES) {
        if (t.includes(term)) return { verdict: 'exc', reason: reason };
    }

    // 2. Check Auto Includes (Molecular Focus)
    for (const term of AUTO_INCLUDES) {
        if (t.includes(term)) return { verdict: 'inc', reason: `Auto-include: ${term}` };
    }

    // 3. Check Geography
    const foundCountry = WEST_AFRICA.find(c => t.includes(c));
    if (foundCountry) {
        return { verdict: 'maybe', reason: `West African country found: ${foundCountry}` };
    }

    return { verdict: 'maybe', reason: 'No definitive markers found in title' };
}

function applyEnhancedPrescreen() {
    if (records.length === 0) return toast("No records loaded.");
    let count = 0;
    records.forEach(r => {
        if (!r.titleDecision || r.decisionSource === 'ps') {
            const res = preScreen(r.title || "");
            r.titleDecision = res.verdict;
            r.prediction = res;
            r.decisionSource = 'ps';
            count++;
        }
    });
    toast(`v33 Pre-screen applied to ${count} records.`);
    saveSession();
}

// standard session functions
function saveSession() {
    const blob = new Blob([JSON.stringify({version: 33, records: records})], {type: 'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `sr_session_v33_${new Date().toISOString().slice(0,10)}.json`;
    a.click();
}

function restoreSession(e) {
    const file = e.target.files[0];
    const reader = new FileReader();
    reader.onload = (ev) => {
        const data = JSON.parse(ev.target.result);
        records = data.records;
        toast(`${records.length} records loaded.`);
        document.getElementById('save-label').textContent = `${records.length} records loaded`;
    };
    reader.readAsText(file);
}

function toast(m) {
    const t = document.getElementById('toast');
    t.textContent = m; t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
}

function switchTab(id) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.getElementById('panel-' + id).classList.add('active');
}
</script>
</body>
</html>
